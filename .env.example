# URL de tu subdominio (El que Nginx está gestionando)
FRONTEND_URL=https://chatwoot.tudominio.com

# Seguridad: Genera una llave secreta segura para Rails
# Puedes generarla en tu terminal con: openssl rand -hex 64
SECRET_KEY_BASE=reemplaza_esto_con_una_cadena_larga_y_segura

# Configuración de Base de Datos
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=postgres
# Cambia esta contraseña
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Configuración de Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Configuración de Almacenamiento (Para adjuntos y fotos de perfil)
# 'local' guardará los archivos en el volumen de Docker. 
ACTIVE_STORAGE_SERVICE=local

# Otras configuraciones (Opcional por ahora, pero necesarias para producción)
# SMTP_DOMAIN=tudominio.com
# SMTP_ADDRESS=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_USERNAME=correo@tudominio.com
# SMTP_PASSWORD=password_correo